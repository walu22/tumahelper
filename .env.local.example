# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Coming soon gate (off by default in code). Keep false on Production.
# COMING_SOON=false
# COMING_SOON=true
# COMING_SOON_BYPASS_SECRET=change-me-to-a-long-random-string

# Enable local login without Supabase (development only — NEVER on Production)
DEV_AUTH_BYPASS=true

# Allow dev test accounts on deployed previews/staging (optional — NEVER on Production)
# ALLOW_DEV_LOGIN=true

# Supabase
# Staging (local / Vercel Preview): https://vvqouitgiiosmszqztxs.supabase.co
# Production (tumahelper.com only): https://bwmojebyakileueoraxs.supabase.co
# See docs/PRODUCTION_ENV_AUDIT.md
NEXT_PUBLIC_SUPABASE_URL=https://vvqouitgiiosmszqztxs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-secret-or-service-role-key

# Auth / OTP (Choose one provider)
# Africa's Talking (Recommended for Zambia)
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_USERNAME=your-username
AFRICAS_TALKING_SENDER_ID=TumaHelper

# OR Twilio (Backup)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=your-twilio-number

# Encryption (32 character key for NRC encryption)
NRC_ENCRYPTION_KEY=your-32-character-secret-key-here

# Storage
SUPABASE_STORAGE_BUCKET=worker-documents

# Cloud Run API proxy (optional). Default: /api/v1 aliases to local /api.
# Only enable when Cloud Run exposes /api/* routes.
# USE_CLOUD_RUN_API=true
# CLOUD_RUN_API_BASE_URL=https://tumahelper-prod-api-550454647742.europe-west1.run.app

# Customer-facing Airtel Money (production)
NEXT_PUBLIC_AIRTEL_MONEY_NUMBER=0972826732
# Optional: shown next to the number once your Airtel account is registered
# NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=TumaHelper Ltd

# Optional: Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-id